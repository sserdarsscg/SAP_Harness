# SAP Datasphere Connection Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

DSP_TENANT_URL=https://your-tenant.eu10.hcs.cloud.sap
DSP_CLIENT_ID=your-client-id
DSP_CLIENT_SECRET=your-client-secret
DSP_TOKEN_URL=https://your-tenant.authentication.eu10.hana.ondemand.com/oauth/token
DSP_AUTH_URL=https://your-tenant.authentication.eu10.hana.ondemand.com/oauth/authorize
DSP_USER_ID=your-user-id

# Datasphere Space & Object metadata
DSP_SPACE_1=your-space-id-1
DSP_SPACE_2=your-space-id-2
DSP_DEFAULT_VIEW=your-view-technical-name

# UI Automation (Playwright) – for share/deploy operations
DSP_UI_USER=your.email@company.com
DSP_UI_PASSWORD=your_password
